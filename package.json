{
  "name": "candyland",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --env-file=.env.local server/proxy.js",
    "build": "vite build",
    "preview": "vite preview",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:kv:create": "wrangler kv namespace create OTP_STORE",
    "cf:kv:list": "wrangler kv namespace list",
    "cf:secret:resend": "wrangler pages secret put RESEND_API_KEY --project-name gumdrop",
    "cf:secret:domain": "wrangler pages secret put ALLOWED_EMAIL_DOMAIN --project-name gumdrop",
    "cf:secret:from": "wrangler pages secret put RESEND_FROM --project-name gumdrop",
    "cf:secrets:list": "wrangler pages secret list --project-name gumdrop",
    "cf:deploy": "pnpm build && wrangler pages deploy dist --project-name gumdrop",
    "cf:dev": "wrangler pages dev dist --live-reload"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.83.0",
    "@carbon/react": "^1.111.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "resend": "^4.5.2",
    "sass": "^1.101.0",
    "vite": "^6.3.5",
    "vite-plugin-svgr": "^5.2.0",
    "wrangler": "^4.110.0"
  }
}
